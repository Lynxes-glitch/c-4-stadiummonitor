{
  "name": "stadium-monitor",
  "version": "2.0.0",
  "description": "Volunteer AI Co-Pilot for FIFA World Cup 2026 Smart Stadiums Challenge — crowd reasoning, graph-based wayfinding, multilingual assistance, and incident triage/escalation.",
  "type": "module",
  "main": "server/index.js",
  "scripts": {
    "build": "node server/build.js",
    "prestart": "npm run build",
    "start": "node server/index.js",
    "dev": "node --watch server/index.js",
    "test": "node --test",
    "test:coverage": "node --experimental-test-coverage --test-reporter=spec --test",
    "test:e2e": "playwright test",
    "lint": "eslint server public/js tests"
  },
  "dependencies": {
    "better-sqlite3": "^12.11.1",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "express-rate-limit": "^7.4.0",
    "helmet": "^7.1.0",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.10.0",
    "@playwright/test": "^1.47.0",
    "eslint": "^8.57.0",
    "terser": "^5.49.0"
  },
  "engines": {
    "node": ">=20"
  },
  "license": "MIT"
}
